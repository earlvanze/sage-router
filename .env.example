# Sage Router example environment.
# Copy to .env (or ~/.config/sage-router/sage-router.env) and edit.
# The local router works with zero keys if you only use free/local providers (e.g. Ollama).

# ── Core ────────────────────────────────────────────────────────────────────
SAGE_ROUTER_HOME=/path/to/sage-router
SAGE_ROUTER_PORT=8790
SAGE_ROUTER_CONFIG_SOURCE=auto

# Optional: require a client API key to call the router (BYOK gateway).
# SAGE_ROUTER_CLIENT_AUTH_REQUIRED=true
# SAGE_ROUTER_CLIENT_API_KEYS=router-secret-1,router-secret-2

# ── Bring your own provider keys (BYOK) ─────────────────────────────────────
# Only set the keys for providers you are authorized to use. Keys stay local.
# OPENAI_API_KEY=...
# ANTHROPIC_API_KEY=...
# SAGE_ROUTER_ANTHROPIC_API_KEY=...
# GEMINI_API_KEY=...
# NIM_API_KEY=...
# SAGE_ROUTER_DARIO_API_KEY=...

# ── Local / hybrid models ───────────────────────────────────────────────────
SAGE_ROUTER_OLLAMA_TIMEOUT_SECONDS=120
SAGE_ROUTER_OLLAMA_AUTO_PULL_PATTERNS=:cloud

# Optional: comma-separated providers/models to suppress.
# SAGE_ROUTER_DISABLED_PROVIDERS=
# SAGE_ROUTER_DISABLED_MODELS=

# ── Optional Sage Cloud analytics sync (off by default) ─────────────────────
# SAGE_ROUTER_ANALYTICS_TOKEN=...
# SAGE_ROUTER_BILLING_ENABLED=false

# ── Optional Codex OAuth passthrough ────────────────────────────────────────
# SAGE_ROUTER_CODEX_OAUTH_ENABLED=false
# SAGE_ROUTER_CODEX_OAUTH_CLIENT_ID=
# SAGE_ROUTER_CODEX_OAUTH_AUTH_BASE_URL=
# SAGE_ROUTER_CODEX_AUTH_PROFILE=
