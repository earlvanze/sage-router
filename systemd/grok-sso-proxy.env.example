# Copy to: ~/.config/sage-router/grok-sso-proxy.env

GROK_SSO_PROXY_HOME=/home/your-user/.openclaw/workspace/skills/sage-router
GROK_SSO_PROXY_PYTHON=python3
GROK_SSO_PROXY_HOST=127.0.0.1
GROK_SSO_PROXY_PORT=18923

# Optional cookie inputs, checked in this order:
# 1) direct cookie header string
# 2) JSON file path
# 3) Chromium cookie DB path
GROK_SSO_PROXY_COOKIE_HEADER=
GROK_SSO_PROXY_COOKIE_JSON=
GROK_SSO_PROXY_BROWSER_PROFILE_DIR=/home/your-user/.config/BraveSoftware/Brave-Browser/Default
GROK_SSO_PROXY_BROWSER_COOKIE_DB=/home/your-user/.config/BraveSoftware/Brave-Browser/Default/Cookies

# Optional runtime behavior
GROK_SSO_PROXY_MODEL=grok-3
GROK_SSO_PROXY_TEMPORARY=true
GROK_SSO_PROXY_DISABLE_SEARCH=false
GROK_SSO_PROXY_REQUIRED_COOKIES=sso
GROK_SSO_PROXY_TIMEOUT_SECONDS=90
GROK_SSO_PROXY_DEBUG=false

# Optional override for local testing with a mock upstream
# GROK_SSO_PROXY_UPSTREAM_BASE_URL=http://127.0.0.1:19091/rest/app-chat
