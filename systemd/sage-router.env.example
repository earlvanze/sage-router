# Copy to: ~/.config/sage-router/sage-router.env
# Then set absolute paths for your machine.

SAGE_ROUTER_HOME=/home/your-user/.openclaw/workspace/skills/sage-router
SAGE_ROUTER_PYTHON=python3
SAGE_ROUTER_PORT=8788

# Optional: prepend extra bins if python3/dario/node are not already on PATH.
# Example:
# SAGE_ROUTER_PATH_PREFIX=/home/your-user/.nvm/versions/node/current/bin:/home/linuxbrew/.linuxbrew/bin
SAGE_ROUTER_PATH_PREFIX=

# Optional extra router args.
SAGE_ROUTER_ARGS=
