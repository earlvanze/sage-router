# Copy to: ~/.config/sage-router/sage-router.env
# Then set absolute paths for your machine.

SMART_ROUTER_HOME=/home/your-user/.openclaw/workspace/skills/sage-router
SMART_ROUTER_PYTHON=python3
SMART_ROUTER_PORT=8788

# Optional: prepend extra bins if python3/dario/node are not already on PATH.
# Example:
# SMART_ROUTER_PATH_PREFIX=/home/your-user/.nvm/versions/node/current/bin:/home/linuxbrew/.linuxbrew/bin
SMART_ROUTER_PATH_PREFIX=

# Optional extra router args.
SMART_ROUTER_ARGS=
