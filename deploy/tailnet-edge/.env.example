SAGE_ROUTER_EDGE_PORT=8790

# Comma-separated Sage Router base URLs reachable from the edge host over Tailnet.
SAGE_ROUTER_UPSTREAMS=http://cyber.example.ts.net:8790,http://umbrel.example.ts.net:8790

# Client-facing token for this edge endpoint. Keep this different from backend router keys.
SAGE_ROUTER_EDGE_TOKEN=change-me-edge-token

# Token injected when proxying to private Sage Router nodes.
SAGE_ROUTER_BACKEND_TOKEN=local

SAGE_ROUTER_HEALTH_PATH=/health
SAGE_ROUTER_HEALTH_INTERVAL_SECONDS=10
SAGE_ROUTER_HEALTH_TIMEOUT_SECONDS=3
SAGE_ROUTER_REQUEST_CONNECT_TIMEOUT_SECONDS=5
