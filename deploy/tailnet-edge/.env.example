SAGE_ROUTER_EDGE_PORT=8790

# Comma-separated Sage Router base URLs reachable from the edge host over Tailnet.
SAGE_ROUTER_UPSTREAMS=http://cyber.example.ts.net:8790,http://umbrel.example.ts.net:8790

# Client-facing token for this edge endpoint. Keep this different from backend router keys.
SAGE_ROUTER_EDGE_TOKEN=change-me-edge-token

# Token injected when proxying to private Sage Router nodes.
SAGE_ROUTER_BACKEND_TOKEN=local

# shared-token preserves the original private Tailnet behavior.
# supabase makes the public edge fail closed: /v1/* requires an active generated
# sk_sage_* customer API key, while account/billing UI routes require a valid
# Supabase user JWT.
SAGE_ROUTER_EDGE_AUTH_MODE=shared-token

# Optional hosted control-plane origin for account/billing routes. Use the
# hosted Sage Router service that has Supabase service-role credentials; model
# routing still uses SAGE_ROUTER_UPSTREAMS and receives SAGE_ROUTER_BACKEND_TOKEN.
# SAGE_ROUTER_CONTROL_PLANE_UPSTREAM=https://sage-router-hosted.example.run.app

# Required only when SAGE_ROUTER_EDGE_AUTH_MODE=supabase.
# SAGE_ROUTER_SUPABASE_URL=https://awtangrlqqsdpksarhwo.supabase.co
# SAGE_ROUTER_SUPABASE_ANON_KEY=...
# SAGE_ROUTER_SUPABASE_SERVICE_ROLE_KEY=...
# SAGE_ROUTER_API_KEY_HASH_PEPPER=...
# SAGE_ROUTER_CORS_ORIGIN=https://app.sagerouter.dev,https://sagerouter.dev,https://www.sagerouter.dev

# Public SaaS abuse limits. The private SAGE_ROUTER_EDGE_TOKEN is exempt.
# Format is plan=requests_per_window, with default used for unknown plans and
# Supabase user-JWT account/billing UI requests.
SAGE_ROUTER_EDGE_RATE_LIMIT_ENABLED=1
SAGE_ROUTER_EDGE_RATE_LIMIT_WINDOW_SECONDS=60
SAGE_ROUTER_EDGE_RATE_LIMITS=trial=30,lite=60,pro=180,max=600,manual=600,paid=180,active=180,default=60

# Supabase user JWT validation is cached by the general auth cache below.
# Generated sk_sage_* API keys default to no auth cache so revocation and
# inactive-account changes take effect on the next request.
SAGE_ROUTER_EDGE_AUTH_CACHE_SECONDS=30
SAGE_ROUTER_EDGE_API_KEY_AUTH_CACHE_SECONDS=0

# Optional monthly SaaS quotas for generated customer API keys. Apply
# ../../supabase/sage_router_saas.sql before enabling this in production.
# Values are requests per UTC calendar month; 0 means no monthly cap for that
# plan/status. Private SAGE_ROUTER_EDGE_TOKEN traffic is exempt.
SAGE_ROUTER_EDGE_QUOTA_ENABLED=0
SAGE_ROUTER_EDGE_MONTHLY_QUOTAS=trial=1000,lite=10000,pro=50000,max=200000,paid=50000,active=50000,default=0

# Optional: lets the hosted operator launch funnel read /analytics* without
# granting /admin* access. Keep SAGE_ROUTER_EDGE_TOKEN for emergency/admin use.
# SAGE_ROUTER_ANALYTICS_TOKEN=

SAGE_ROUTER_HEALTH_PATH=/health
SAGE_ROUTER_HEALTH_INTERVAL_SECONDS=10
SAGE_ROUTER_HEALTH_TIMEOUT_SECONDS=3
SAGE_ROUTER_REQUEST_TIMEOUT_SECONDS=120
