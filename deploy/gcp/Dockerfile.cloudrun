FROM node:22-bookworm-slim

ENV PYTHONUNBUFFERED=1 \
    PORT=8080 \
    SAGE_ROUTER_HOME=/app \
    SAGE_ROUTER_BUNDLED_OLLAMA_AUTOSTART=1 \
    SAGE_ROUTER_OLLAMA_AUTO_PULL_PATTERNS= \
    SAGE_ROUTER_DARIO_AUTOSTART=1 \
    SAGE_ROUTER_DARIO_BASE_URL=http://127.0.0.1:3456 \
    OLLAMA_HOST=127.0.0.1:11434 \
    OLLAMA_MODELS=/tmp/ollama/models

ARG OLLAMA_DOWNLOAD_URL=https://github.com/ollama/ollama/releases/latest/download/ollama-linux-amd64.tar.zst

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 ca-certificates curl zstd \
    && rm -rf /var/lib/apt/lists/* \
    && npm install -g @askalf/dario \
    && curl -fsSL "$OLLAMA_DOWNLOAD_URL" | tar --zstd -x -C /usr/local

WORKDIR /app
COPY router.py provider-profiles.json router-profiles.json requirements.txt ./
COPY scripts ./scripts
COPY web/dashboard ./web/dashboard

EXPOSE 8080 11434 3456
HEALTHCHECK --interval=30s --timeout=10s --retries=3 --start-period=10s \
  CMD python3 -c "import urllib.request, os; urllib.request.urlopen('http://127.0.0.1:%s/health' % os.environ.get('PORT','8080'), timeout=5)"

CMD ["sh", "-c", "mkdir -p /tmp/ollama/models /root/.dario && ollama serve >/tmp/ollama.log 2>&1 & dario proxy --host 127.0.0.1 --port 3456 >/tmp/dario.log 2>&1 & python3 /app/router.py --port ${PORT:-8080}"]
