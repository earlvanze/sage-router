        "*2b*",
        "*3b*",
        "*4b*",
        "*7b*",
        "*8b*",
        "*claude*",
        "*deepseek-r1*",
        "*deepseek-v3*",
        "*flash-lite*",
        "*gemini*",
        "*gemma-3n*",
        "*glm-4*",
        "*haiku*",
        "*laguna-xs*",
        "*lfm-2.5*",
        "*llama*",
        "*mini*",
        "*minimax-m2.5*",
        "*mistral-large-2*",
        "*nemo*",
        "*nemotron*",
        "*trinity*"
