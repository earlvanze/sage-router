{
  "profiles": {
    "auto": {
      "description": "Default reliable auto-routing for first requests and general hosted traffic.",
      "route": "balanced",
      "thinking": "medium",
      "defaultModel": "google/gemini-2.5-flash",
      "allowProviders": [
        "google",
        "google-vertex",
        "openrouter",
        "nvidia-nim",
        "openai",
        "openai-codex"
      ],
      "fallbackProviders": [
        "google",
        "google-vertex",
        "openrouter",
        "nvidia-nim",
        "openai",
        "openai-codex"
      ],
      "allowModels": [
        "*gemini-2.5-flash*",
        "*gemini-3-flash*"
      ],
      "suppressIntermediateToolText": true
    },
    "balanced": {
      "description": "Balanced routing prefers Ollama subscription/local providers first for cost, with Codex and cloud providers as fallbacks.",
      "route": "balanced",
      "thinking": "medium",
      "allowProviders": [
        "ollama-cyber",
        "ollama"
      ],
      "fallbackProviders": [
        "openai-codex",
        "google",
        "google-vertex",
        "openrouter",
        "nvidia-nim",
        "openai"
      ],
      "suppressIntermediateToolText": true
    },
    "frontier": {
      "description": "Frontier routing via OpenClaw Codex OAuth with cloud fallbacks.",
      "route": "best",
      "thinking": "high",
      "requiresQuality": true,
      "requiresReasoning": true,
      "allowProviders": [
        "openai-codex"
      ],
      "fallbackProviders": [
        "ollama-cyber",
        "ollama",
        "google",
        "google-vertex",
        "openrouter",
        "nvidia-nim",
        "openai"
      ],
      "frontierLargeOnly": true,
      "suppressIntermediateToolText": true,
      "allowModels": [
        "*gpt-5*",
        "*codex*",
        "*glm-5*",
        "*kimi-k2*",
        "*deepseek-v4*",
        "*qwen3.[5-9]*",
        "*minimax-m2.[7-9]*",
        "*minimax-m3*",
        "*mistral-large-3*",
        "*qwen3.5:397b-cloud*",
        "*cogito-2.1:671b-cloud*",
        "*devstral-2:123b-cloud*",
        "google/gemini-3-flash-preview",
        "google/gemini-2.5-pro",
        "google-vertex/gemini-3-flash-preview",
        "google-vertex/gemini-2.5-pro"
      ],
      "verbosity": "low",
      "maxPublicAnswerBullets": 3,
      "style": "direct concise public-safe no-fluff",
      "responsePolicy": {
        "defaultLength": "short",
        "leadWithAnswer": true,
        "avoidPreambles": true,
        "avoidProcessNarration": true,
        "preferBullets": "1-3 when useful",
        "expandOnlyWhenAsked": true
      }
    },
    "fusion": {
      "description": "Premium multi-model panel plus judge synthesis for high-stakes prompts.",
      "route": "best",
      "thinking": "high",
      "requiresQuality": true,
      "requiresReasoning": true,
      "frontierLargeOnly": true,
      "suppressIntermediateToolText": true,
      "allowProviders": [
        "openai-codex"
      ],
      "fallbackProviders": [
        "ollama-cyber",
        "ollama",
        "google",
        "google-vertex",
        "openrouter",
        "nvidia-nim",
        "openai"
      ],
      "denyModels": [
        "*-mini*", "*:mini*", "*mini/*",
        "*haiku*",
        "*1.2b*",
        "*3b*",
        "*7b*",
        "*8b*"
      ]
    },
    "agentic": {
      "description": "Agentic routing — prefers models with reliable tool-calling and autonomous task behavior via OpenClaw Codex OAuth.",
      "route": "best",
      "thinking": "high",
      "agentic": true,
      "requiresQuality": true,
      "requiresReasoning": true,
      "preferTools": true,
      "allowProviders": [
        "openai-codex"
      ],
      "fallbackProviders": [
        "ollama-cyber",
        "ollama",
        "google",
        "google-vertex",
        "openrouter",
        "nvidia-nim",
        "openai"
      ],
      "frontierLargeOnly": true,
      "suppressIntermediateToolText": true,
      "denyModels": [
        "*-mini*", "*:mini*", "*mini/*", "*haiku*", "*1.2b*", "*3b*", "*7b*", "*8b*",
        "*flash-lite*", "*nano*", "*nemo*"
      ]
    },
    "frontier-large": {
      "description": "Strict frontier/large-model-only routing.",
      "route": "best",
      "thinking": "high",
      "requiresQuality": true,
      "requiresReasoning": true,
      "frontierLargeOnly": true
    },
    "fast-local": {
      "description": "Low-latency local/LAN routing.",
      "route": "local-first",
      "thinking": "low"
    },
    "coding-max": {
      "description": "High-thinking coding route.",
      "route": "best",
      "thinking": "high",
      "requiresReasoning": true,
      "qualitySensitive": true,
      "denyModels": [
        "*-mini*", "*:mini*", "*mini/*",
        "*haiku*",
        "*1.2b*",
        "*3b*",
        "*7b*",
        "*8b*"
      ]
    },
    "discord-public": {
      "description": "Public Discord-safe quality routing with hidden thinking/tool narration suppressed.",
      "route": "best",
      "thinking": "high",
      "requiresQuality": true,
      "requiresReasoning": true,
      "frontierOrReasoningTools": true,
      "allowProviders": [
        "openai-codex"
      ],
      "fallbackProviders": [
        "ollama-cyber",
        "ollama",
        "google",
        "google-vertex",
        "openrouter",
        "nvidia-nim",
        "openai"
      ],
      "suppressIntermediateToolText": true,
      "denyModels": [
        "*-mini*", "*:mini*", "*mini/*",
        "*haiku*",
        "*1.2b*",
        "*3b*",
        "*7b*",
        "*8b*"
      ]
    }
  }
}
